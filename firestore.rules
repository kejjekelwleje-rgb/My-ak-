rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - createdAt: number (required)
    //
    // Collection: users/{userId}/messages
    // Document ID: {messageId}
    // Fields:
    //   - role: string (required, 'user' or 'model')
    //   - text: string (required)
    //   - imageUrl: string (optional)
    //   - timestamp: number (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser() {
      let data = request.resource.data;
      let hasRequired = data.keys().hasAll(['uid', 'email', 'createdAt']);
      let hasOnlyAllowed = data.keys().hasOnly(['uid', 'email', 'displayName', 'photoURL', 'createdAt']);
      
      return hasRequired && hasOnlyAllowed &&
             data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 255 &&
             data.createdAt is number &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 2000));
    }

    function isValidMessage() {
      let data = request.resource.data;
      let hasRequired = data.keys().hasAll(['role', 'text', 'timestamp']);
      let hasOnlyAllowed = data.keys().hasOnly(['role', 'text', 'imageUrl', 'timestamp']);
      
      return hasRequired && hasOnlyAllowed &&
             data.role in ['user', 'model'] &&
             data.text is string && data.text.size() <= 100000 &&
             data.timestamp is number &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 2000000));
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser();
      allow update: if isOwner(userId) && isValidUser() && 
                    request.resource.data.createdAt == resource.data.createdAt && 
                    request.resource.data.uid == resource.data.uid;
      
      match /messages/{messageId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidMessage();
        allow update: if isOwner(userId) && isValidMessage();
        allow delete: if isOwner(userId);
      }
    }
  }
}
